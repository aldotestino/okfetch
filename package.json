{
  "name": "@okfetch/root",
  "private": true,
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "examples/*",
    "apps/*"
  ],
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "build:watch": "tsdown --watch",
    "changeset": "changeset",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepare": "husky",
    "release": "bun run build && changeset publish --access public",
    "typecheck": "bunx tsc --noEmit && cd apps/docs && bun run types:check",
    "version-packages": "changeset version && bun install"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@types/bun": "latest",
    "husky": "^9.1.7",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "tsdown": "latest",
    "ultracite": "7.2.4"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
