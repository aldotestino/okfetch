{
  "name": "@okfetch/fetch",
  "version": "0.1.1",
  "description": "A type-safe fetch wrapper with validation, retries, plugins, and streaming.",
  "keywords": [
    "fetch",
    "http",
    "typescript",
    "validation",
    "zod"
  ],
  "homepage": "https://github.com/okfetch/okfetch#readme",
  "bugs": {
    "url": "https://github.com/okfetch/okfetch/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/okfetch/okfetch.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "better-result": "^2.7.0",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "better-result": "^2.7.0",
    "typescript": "^5",
    "zod": "^4.3.6"
  }
}
