{
  "name": "@okfetch/logger",
  "version": "0.2.0",
  "description": "A pino-based logging plugin for okfetch request lifecycles.",
  "keywords": [
    "fetch",
    "logging",
    "pino",
    "plugin",
    "typescript"
  ],
  "homepage": "https://github.com/aldotestino/okfetch#readme",
  "bugs": {
    "url": "https://github.com/aldotestino/okfetch/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aldotestino/okfetch.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@okfetch/fetch": "^0.2.0",
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "@okfetch/fetch": "^0.2.0",
    "pino": "^10.3.1",
    "typescript": "^5"
  }
}
