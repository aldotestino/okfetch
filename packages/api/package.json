{
  "name": "@okfetch/api",
  "version": "0.2.0",
  "description": "A typed API client builder for okfetch based on endpoint schemas.",
  "keywords": [
    "api-client",
    "fetch",
    "standard-schema",
    "typescript",
    "validation"
  ],
  "homepage": "https://github.com/aldotestino/okfetch#readme",
  "bugs": {
    "url": "https://github.com/aldotestino/okfetch/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aldotestino/okfetch.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@okfetch/fetch": "^0.2.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "better-result": "^2.7.0",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@okfetch/fetch": "^0.2.0",
    "better-result": "^2.7.0",
    "typescript": "^5"
  }
}
